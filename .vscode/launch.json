    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Level Editor",
            "type": "godot",
            "request": "launch",
            "project": "${workspaceFolder}",
            "scene": "${workspaceFolder}/Scenes/level_editor.tscn"
        },
        {
            "name": "Launch Project",
            "type": "godot",
            "request": "launch",
            "project": "${workspaceFolder}",
            "scene": "main",
            "debug_collisions": false,
            "debug_paths": false,
            "debug_navigation": false,
            "additional_options": ""
        },
        {
            "name": "GDScript: Launch Current File",
            "type": "godot",
            "request": "launch",
            "scene": "current",
            "project": "",
            "additional_options": ""
        },
        
    ]
}